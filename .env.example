# data.go.kr "일반 인증키" (하나만 있으면 됨)
# 인코딩 키(%2B·%2F 포함)든 디코딩 키든 상관없음 — probe.py가 알아서 처리함.
# 행안부 gov24 + 사회보장정보원 복지서비스 공용 키
DATA_GO_KR_KEY=여기에_일반인증키

# 온통청년 청년정책 API 별도 키
YOUTH_API_KEY=여기에_온통청년_키

# Gemini 생성 키 — Google AI Studio 무료 발급: https://aistudio.google.com/apikey
# (임베딩은 로컬 모델 사용. 이 키는 이후 RAG 답변 생성 단계에서 씀)
GEMINI_API_KEY=여기에_Gemini_키

# Postgres 연결 문자열 — Neon 무료: https://neon.tech (pgvector 지원)
# 예: postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=여기에_연결문자열
